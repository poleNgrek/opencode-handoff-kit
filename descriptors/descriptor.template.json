{
  "projectKey": "my-project",
  "projectRootPath": "~/projects/my-project",
  "opencodeProjectRootPath": "~/.config/opencode/projects/my-project",
  "baselineBranchForMaterialChanges": "main",
  "areas": {
    "frontend": {
      "pathPrefix": "frontend",
      "areaAgentsPath": "~/.config/opencode/projects/my-project/frontend/AGENTS.md",
      "commandsRoot": "frontend"
    },
    "backend": {
      "pathPrefix": "backend",
      "areaAgentsPath": "~/.config/opencode/projects/my-project/backend/AGENTS.md",
      "commandsRoot": "backend"
    },
    "cli": {
      "pathPrefix": "cli",
      "areaAgentsPath": "~/.config/opencode/projects/my-project/cli/AGENTS.md",
      "commandsRoot": "cli"
    }
  },
  "pseudoPackageDetection": {
    "kind": "pathAndAlias",
    "pathPattern": "frontend/src/{packageName}/**/*",
    "aliases": ["@org/{packageName}"]
  },
  "trackedKnowledgeTargets": {
    "sharedPackageKnowledge": {},
    "trackedAreas": ["frontend", "backend", "cli"]
  },
  "branchHandoff": {
    "contextDirTemplate": "~/.config/opencode/projects/{projectKey}/branches/{branchName}",
    "mrFilename": "MERGE_REQUEST.md",
    "logFilename": "LOG.md",
    "phasesFilename": "PHASES.md",
    "phasesOptional": true,
    "checkpointField": "reviewed_through",
    "templatesDir": "~/.config/opencode/projects/{projectKey}/_templates/mr",
    "mrTemplateFilename": "MERGE_REQUEST.md",
    "logTemplateFilename": "LOG.md",
    "phasesTemplateFilename": "PHASES.md",
    "mrBranchPlaceholder": "<branch-name>"
  },
  "refreshToolHeuristics": {
    "changedFilesAreaPrefixes": ["frontend/", "backend/", "cli/"],
    "highSignalChangedSubstrings": [
      "package.json",
      "tsconfig",
      "eslint.config",
      "pyproject.toml",
      "go.mod"
    ]
  }
}

